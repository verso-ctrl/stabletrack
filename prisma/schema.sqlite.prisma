// BarnKeep Database Schema - SQLite (Local Demo)
// For local development without external services

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ============================================================================
// USER & AUTHENTICATION (Simplified for demo - no Clerk)
// ============================================================================

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  firstName   String?
  lastName    String?
  avatarUrl   String?
  phone       String?
  timezone    String   @default("America/New_York")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscription    Subscription?
  barnMemberships BarnMember[]
  createdNotes    Note[]
  assignedTasks   Task[]
  activityLogs    ActivityLog[]
}

// ============================================================================
// SUBSCRIPTION (Simplified - no Stripe)
// ============================================================================

model Subscription {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  tier      String   @default("STARTER")
  status    String   @default("ACTIVE")
  
  maxHorses Int      @default(999)
  maxBarns  Int      @default(10)
  storageGb Int      @default(50)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// BARN & TEAM
// ============================================================================

model Barn {
  id          String   @id @default(cuid())
  name        String
  address     String?
  city        String?
  state       String?
  zipCode     String?
  country     String   @default("US")
  phone       String?
  email       String?
  timezone    String   @default("America/New_York")
  inviteCode  String   @unique
  logoUrl     String?
  
  // Billing fields
  invoicePrefix        String?
  nextInvoiceNumber    Int      @default(1)
  defaultPaymentTerms  Int      @default(30)
  taxRate              Float    @default(0)
  
  // Google Calendar integration
  googleCalendarEnabled Boolean  @default(false)
  googleCalendarId      String?
  googleAccessToken     String?
  googleRefreshToken    String?
  googleSyncEvents      Boolean  @default(true)
  googleSyncLessons     Boolean  @default(true)
  googleSyncCompetitions Boolean @default(true)
  lastGoogleSync        DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     BarnMember[]
  horses      Horse[]
  stalls      Stall[]
  paddocks    Paddock[]
  feedTypes   FeedType[]
  supplements Supplement[]
  events      Event[]
  tasks       Task[]
  activityLogs ActivityLog[]
  inventory   InventoryItem[]
  clients     Client[]
}

model BarnMember {
  id         String    @id @default(cuid())
  userId     String
  barnId     String
  role       String    @default("OWNER")
  status     String    @default("ACTIVE")
  joinedAt   DateTime  @default(now())
  approvedAt DateTime?
  approvedBy String?
  
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  barn       Barn      @relation(fields: [barnId], references: [id], onDelete: Cascade)
  
  horseAccess HorseAccess[]

  @@unique([userId, barnId])
}

model HorseAccess {
  id           String     @id @default(cuid())
  barnMemberId String
  horseId      String
  
  barnMember   BarnMember @relation(fields: [barnMemberId], references: [id], onDelete: Cascade)
  horse        Horse      @relation(fields: [horseId], references: [id], onDelete: Cascade)

  @@unique([barnMemberId, horseId])
}

// ============================================================================
// FACILITIES
// ============================================================================

model Stall {
  id        String   @id @default(cuid())
  barnId    String
  name      String
  section   String?
  
  barn      Barn     @relation(fields: [barnId], references: [id], onDelete: Cascade)
  horse     Horse?   @relation("CurrentStall")
  
  @@unique([barnId, name])
}

model Paddock {
  id        String   @id @default(cuid())
  barnId    String
  name      String
  acreage   Float?
  maxHorses Int?
  
  barn      Barn     @relation(fields: [barnId], references: [id], onDelete: Cascade)
  turnouts  HorseTurnout[]
  
  @@unique([barnId, name])
}

// ============================================================================
// HORSES
// ============================================================================

model Horse {
  id              String    @id @default(cuid())
  barnId          String
  barnName        String
  registeredName  String?
  breed           String?
  color           String?
  markings        String?
  dateOfBirth     DateTime?
  sex             String?
  heightHands     Float?
  microchipNumber String?
  status          String    @default("ACTIVE")
  isPrivate       Boolean   @default(false)
  ownerName       String?
  ownerEmail      String?
  ownerPhone      String?
  profilePhotoUrl String?
  bio             String?
  stallId         String?   @unique
  sireId          String?
  damId           String?
  sireName        String?
  damName         String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  barn            Barn      @relation(fields: [barnId], references: [id], onDelete: Cascade)
  stall           Stall?    @relation("CurrentStall", fields: [stallId], references: [id])
  sire            Horse?    @relation("Sire", fields: [sireId], references: [id])
  dam             Horse?    @relation("Dam", fields: [damId], references: [id])
  sireOf          Horse[]   @relation("Sire")
  damOf           Horse[]   @relation("Dam")
  
  weightRecords   WeightRecord[]
  vaccinations    Vaccination[]
  medications     Medication[]
  healthRecords   HealthRecord[]
  feedProgram     FeedProgram?
  feedLogs        FeedLog[]
  waterLogs       WaterLog[]
  photos          HorsePhoto[]
  documents       Document[]
  notes           Note[]
  events          Event[]
  turnouts        HorseTurnout[]
  accessGrants    HorseAccess[]
  dailyHealthChecks DailyHealthCheck[]
  clientHorses    ClientHorse[]
}

model HorsePhoto {
  id          String   @id @default(cuid())
  horseId     String
  url         String
  storagePath String?
  fileName    String?
  fileSize    Int?
  mimeType    String?
  caption     String?
  category    String?
  isPrimary   Boolean  @default(false)
  uploadedBy  String?
  uploadedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  
  horse       Horse    @relation(fields: [horseId], references: [id], onDelete: Cascade)
}

model HorseTurnout {
  id        String    @id @default(cuid())
  horseId   String
  paddockId String
  startTime DateTime  @default(now())
  endTime   DateTime?
  
  horse     Horse     @relation(fields: [horseId], references: [id], onDelete: Cascade)
  paddock   Paddock   @relation(fields: [paddockId], references: [id], onDelete: Cascade)
}

// ============================================================================
// FEED & NUTRITION
// ============================================================================

model FeedType {
  id          String   @id @default(cuid())
  barnId      String
  name        String
  brand       String?
  category    String?
  unit        String   @default("lbs")
  costPerUnit Float?
  notes       String?
  
  barn        Barn     @relation(fields: [barnId], references: [id], onDelete: Cascade)
  feedItems   FeedProgramItem[]
  feedLogs    FeedLog[]
  
  @@unique([barnId, name])
}

model Supplement {
  id          String   @id @default(cuid())
  barnId      String
  name        String
  brand       String?
  unit        String   @default("scoops")
  costPerUnit Float?
  notes       String?
  
  barn        Barn     @relation(fields: [barnId], references: [id], onDelete: Cascade)
  feedItems   FeedProgramItem[]
  
  @@unique([barnId, name])
}

model FeedProgram {
  id              String   @id @default(cuid())
  horseId         String   @unique
  name            String?
  instructions    String?
  estimatedDailyCost Float?
  
  horse           Horse    @relation(fields: [horseId], references: [id], onDelete: Cascade)
  items           FeedProgramItem[]
}

model FeedProgramItem {
  id            String   @id @default(cuid())
  feedProgramId String
  feedTypeId    String?
  supplementId  String?
  customName    String?
  amount        Float
  unit          String
  feedingTime   String
  notes         String?
  
  feedProgram   FeedProgram @relation(fields: [feedProgramId], references: [id], onDelete: Cascade)
  feedType      FeedType?   @relation(fields: [feedTypeId], references: [id])
  supplement    Supplement? @relation(fields: [supplementId], references: [id])
}

model FeedLog {
  id          String   @id @default(cuid())
  horseId     String
  feedTypeId  String?
  feedingTime String
  amount      Float?
  amountEaten String?
  notes       String?
  loggedAt    DateTime @default(now())
  loggedBy    String?
  
  horse       Horse    @relation(fields: [horseId], references: [id], onDelete: Cascade)
  feedType    FeedType? @relation(fields: [feedTypeId], references: [id])
}

// Water tracking
model WaterLog {
  id          String   @id @default(cuid())
  horseId     String
  date        DateTime @default(now())
  waterLevel  String?
  quality     String?
  refilled    Boolean  @default(false)
  notes       String?
  loggedBy    String?
  
  horse       Horse    @relation(fields: [horseId], references: [id], onDelete: Cascade)
}

// ============================================================================
// HEALTH & MEDICAL
// ============================================================================

model WeightRecord {
  id             String   @id @default(cuid())
  horseId        String
  weightLbs      Float
  bodyCondition  Int?
  date           DateTime @default(now())
  notes          String?
  
  horse          Horse    @relation(fields: [horseId], references: [id], onDelete: Cascade)
}

model Vaccination {
  id           String    @id @default(cuid())
  horseId      String
  type         String
  customType   String?
  dateGiven    DateTime
  nextDueDate  DateTime?
  veterinarian String?
  manufacturer String?
  lotNumber    String?
  notes        String?
  
  horse        Horse     @relation(fields: [horseId], references: [id], onDelete: Cascade)
}

model Medication {
  id                 String    @id @default(cuid())
  horseId            String
  name               String
  dosage             String
  frequency          String
  route              String?
  prescribingVet     String?
  startDate          DateTime
  endDate            DateTime?
  status             String    @default("ACTIVE")
  isControlled       Boolean   @default(false)
  refillsRemaining   Int?
  pharmacy           String?
  instructions       String?
  
  horse              Horse     @relation(fields: [horseId], references: [id], onDelete: Cascade)
  logs               MedicationLog[]
}

model MedicationLog {
  id           String   @id @default(cuid())
  medicationId String
  givenAt      DateTime @default(now())
  givenBy      String?
  skipped      Boolean  @default(false)
  skipReason   String?
  notes        String?
  
  medication   Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)
}

model HealthRecord {
  id              String    @id @default(cuid())
  horseId         String
  type            String
  date            DateTime
  provider        String?
  diagnosis       String?
  treatment       String?
  findings        String?
  followUpDate    DateTime?
  followUpNotes   String?
  cost            Int?
  cogginsExpiry   DateTime?
  
  horse           Horse     @relation(fields: [horseId], references: [id], onDelete: Cascade)
  attachments     HealthAttachment[]
}

model HealthAttachment {
  id             String       @id @default(cuid())
  healthRecordId String
  fileName       String
  fileUrl        String
  fileType       String?
  uploadedAt     DateTime     @default(now())
  
  healthRecord   HealthRecord @relation(fields: [healthRecordId], references: [id], onDelete: Cascade)
}

// ============================================================================
// EVENTS & SCHEDULING
// ============================================================================

model Event {
  id              String    @id @default(cuid())
  barnId          String
  horseId         String?
  type            String
  customType      String?
  title           String
  description     String?
  scheduledDate   DateTime
  completedDate   DateTime?
  status          String    @default("SCHEDULED")
  providerName    String?
  providerPhone   String?
  farrierWork     String?
  shoeingCycle    Int?
  dewormProduct   String?
  fecalEggCount   Int?
  isRecurring     Boolean   @default(false)
  recurringRule   String?
  cost            Int?
  notes           String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  barn            Barn      @relation(fields: [barnId], references: [id], onDelete: Cascade)
  horse           Horse?    @relation(fields: [horseId], references: [id])
  reminders       EventReminder[]
}

model EventReminder {
  id         String   @id @default(cuid())
  eventId    String
  daysBefore Int
  method     String
  sent       Boolean  @default(false)
  sentAt     DateTime?
  
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

// ============================================================================
// TASKS
// ============================================================================

model Task {
  id          String    @id @default(cuid())
  barnId      String
  title       String
  description String?
  dueDate     DateTime?
  dueTime     String?
  priority    String    @default("MEDIUM")
  status      String    @default("PENDING")
  isRecurring Boolean   @default(false)
  recurringRule String?
  assigneeId  String?
  completedAt DateTime?
  completedBy String?
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  barn        Barn      @relation(fields: [barnId], references: [id], onDelete: Cascade)
  assignee    User?     @relation(fields: [assigneeId], references: [id])
}

// ============================================================================
// DOCUMENTS & NOTES
// ============================================================================

model Document {
  id          String    @id @default(cuid())
  horseId     String
  type        String
  title       String
  name        String?
  fileName    String
  url         String?
  fileUrl     String
  storagePath String?
  fileSize    Int?
  mimeType    String?
  expiryDate  DateTime?
  notes       String?
  uploadedAt  DateTime  @default(now())
  uploadedBy  String?
  
  horse       Horse     @relation(fields: [horseId], references: [id], onDelete: Cascade)
}

model Note {
  id        String   @id @default(cuid())
  horseId   String
  content   String
  isPinned  Boolean  @default(false)
  isPrivate Boolean  @default(false)
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  horse     Horse    @relation(fields: [horseId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [createdBy], references: [id])
}

model InventoryItem {
  id           String   @id @default(cuid())
  barnId       String
  name         String
  category     String?
  quantity     Float
  unit         String?
  reorderLevel Float?
  cost         Float?
  supplier     String?
  notes        String?
  updatedAt    DateTime @updatedAt
  
  barn         Barn     @relation(fields: [barnId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id          String   @id @default(cuid())
  barnId      String
  userId      String?
  type        String
  description String
  metadata    String?
  createdAt   DateTime @default(now())
  
  barn        Barn     @relation(fields: [barnId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id])
}

// Daily health observations
model DailyHealthCheck {
  id              String   @id @default(cuid())
  horseId         String
  date            DateTime @default(now())
  
  // Vitals
  temperature     Float?
  heartRate       Int?
  respiratoryRate Int?
  
  // Observations
  overallCondition String?
  appetite         String?
  manure           String?
  attitude         String?
  
  notes           String?
  checkedBy       String?
  createdAt       DateTime @default(now())
  
  horse           Horse    @relation(fields: [horseId], references: [id], onDelete: Cascade)
}

// ============================================================================
// CLIENTS (Horse Owners/Boarders)
// ============================================================================

model Client {
  id            String   @id @default(cuid())
  barnId        String
  userId        String?
  firstName     String
  lastName      String
  name          String?
  email         String?
  phone         String?
  address       String?
  city          String?
  state         String?
  zipCode       String?
  notes         String?
  status        String   @default("ACTIVE")
  portalEnabled Boolean  @default(false)
  portalToken   String?
  balance       Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  barn          Barn     @relation(fields: [barnId], references: [id], onDelete: Cascade)
  horses        ClientHorse[]

  @@index([barnId])
}

model ClientHorse {
  id        String   @id @default(cuid())
  clientId  String
  horseId   String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  horse     Horse    @relation(fields: [horseId], references: [id], onDelete: Cascade)
  
  @@unique([clientId, horseId])
}
